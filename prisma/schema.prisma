generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

model Project {
  id         String      @id @default(cuid())
  name       String
  lastConfig Json?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  runs       SearchRun[]

  @@index([updatedAt(sort: Desc)])
}

model SearchRun {
  id                  String     @id @default(cuid())
  projectId           String
  project             Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status              RunStatus  @default(QUEUED)
  plannedRequestCount Int
  estimatedCostBand   String
  warnings            Json?
  config              Json
  errorMessage        String?
  startedAt           DateTime?
  finishedAt          DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  runPlaces           RunPlace[]

  @@index([projectId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model PlaceReference {
  placeId    String     @id
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  runPlaces  RunPlace[]
}

model RunPlace {
  id               String         @id @default(cuid())
  runId             String
  run               SearchRun      @relation(fields: [runId], references: [id], onDelete: Cascade)
  placeId           String
  placeReference    PlaceReference @relation(fields: [placeId], references: [placeId], onDelete: Restrict)
  displayName       String
  formattedAddress  String
  lat               Float
  lng               Float
  primaryType       String?
  rating            Float?
  userRatingCount   Int?
  websiteUri        String?
  googleMapsUri     String
  businessStatus    String?
  expiresAt         DateTime
  createdAt         DateTime       @default(now())

  @@index([runId])
  @@index([placeId])
  @@index([expiresAt])
}
